{
  "name": "fivosense",
  "version": "0.2.0",
  "description": "AI Security Guardian - Real-time vulnerability detection with taint-trace proofs",
  "author": "thevinsoni",
  "license": "MIT",
  "keywords": ["security", "vulnerability", "taint-analysis", "sql-injection", "xss", "secrets"],
  "activation": {
    "filePatterns": ["*.js", "*.ts", "*.jsx", "*.tsx"],
    "events": ["beforeWrite", "beforeExec", "afterGenerate"]
  },
  "commands": {
    "scan": "npx fivosense",
    "roast": "npx fivosense --roast",
    "badge": "npx fivosense --badge"
  },
  "dependencies": {
    "npm": "fivosense@^0.2.0"
  }
}
